# Server
PORT=5000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ivaworks

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS — allowed frontend origins
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Uploads
UPLOAD_MAX_MB=5

# Email notifications (form submissions → your inbox)
EMAIL_ENABLED=true
NOTIFY_EMAIL=your-email@example.com
MAIL_FROM="IVA Works <noreply@yourdomain.com>"

# SMTP — Gmail example (use an App Password, not your regular password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-gmail-app-password
# Set false on local Windows if antivirus/proxy causes certificate errors (use true in production)
# SMTP_TLS_REJECT_UNAUTHORIZED=false

# SMTP — Outlook / Microsoft 365 example
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password
