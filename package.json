{
  "name": "ivaworks",
  "private": true,
  "workspaces": [
    "frontend",
    "admin",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=ivaworks-frontend",
    "dev:admin": "npm run dev --workspace=ivaworks-admin",
    "dev:backend": "npm run dev --workspace=ivaworks-backend",
    "build:frontend": "npm run build --workspace=ivaworks-frontend",
    "build:admin": "npm run build --workspace=ivaworks-admin",
    "build": "npm run build:frontend && npm run build:admin"
  }
}
